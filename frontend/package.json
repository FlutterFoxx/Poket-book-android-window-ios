{
  "name": "poketbook-desktop",
  "version": "1.1.0",
  "private": true,
  "main": "electron.js",
  "homepage": "https://poketbook.in",
  "dependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/core": "6.2.0",
    "@capacitor/ios": "6.2.0",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-toast": "^1.2.11",
    "@radix-ui/react-tooltip": "^1.2.4",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cra-template": "1.2.0",
    "lucide-react": "^0.507.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.1",
    "react-scripts": "5.0.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "electron": "electron .",
    "electron:build": "craco build && electron-builder",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "in.poketbook.desktop",
    "productName": "PoketBook",
    "copyright": "Copyright \u00a9 2026 Flutter Fox",
    "directories": {
      "output": "dist-electron",
      "buildResources": "public"
    },
    "files": [
      "electron.js",
      "public/**/*",
      "!public/index.html",
      "!src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo512.png",
      "publisherName": "Flutter Fox"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PoketBook"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo512.png",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo512.png",
      "category": "Finance"
    },
    "extraFiles": []
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@capacitor/cli": "6.2.0",
    "@craco/craco": "^7.1.0",
    "autoprefixer": "^10.4.20",
    "electron": "31",
    "electron-builder": "24",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}